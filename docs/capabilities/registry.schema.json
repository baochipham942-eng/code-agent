{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://code-agent.local/schemas/capability-registry.schema.json",
  "title": "Agent Neo local curated capability registry",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "source": {
      "$ref": "#/$defs/source"
    },
    "items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/item"
      }
    }
  },
  "required": ["items"],
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "author": { "type": "string", "minLength": 1 },
        "reviewedAt": { "type": "string", "minLength": 1 },
        "expiresAt": { "type": "string", "minLength": 1 },
        "signedAt": { "type": "string", "minLength": 1 },
        "keyId": { "type": "string", "minLength": 1 },
        "signature": { "type": "string", "minLength": 1 },
        "contentHash": {
          "type": "string",
          "pattern": "^sha256:[A-Fa-f0-9]{64}$"
        }
      }
    },
    "item": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": {
          "enum": ["mcp_template", "channel_adapter", "workflow_recipe"]
        },
        "name": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "source": {
          "$ref": "#/$defs/source"
        },
        "permissions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/permission"
          }
        },
        "config": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/requirement"
          }
        },
        "dependencies": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/requirement"
          }
        },
        "risk": {
          "$ref": "#/$defs/risk"
        },
        "audit": {
          "$ref": "#/$defs/audit"
        },
        "install": {
          "$ref": "#/$defs/install"
        }
      },
      "required": ["id", "kind", "name", "summary"]
    },
    "permission": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "level": { "enum": ["low", "medium", "high"] },
        "detail": { "type": "string" }
      },
      "required": ["label"]
    },
    "requirement": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "kind": {
          "enum": ["env", "secret", "binary", "path", "network", "account", "config"]
        },
        "label": { "type": "string", "minLength": 1 },
        "value": { "type": "string" },
        "status": {
          "enum": ["met", "missing", "unknown", "not_applicable"]
        },
        "sensitive": { "type": "boolean" }
      },
      "required": ["label"]
    },
    "risk": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "tier": { "enum": ["low", "medium", "high"] },
        "reasons": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "dataTouched": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "audit": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "notes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "install": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "mcpServer": {
          "$ref": "#/$defs/mcpServerDraft"
        }
      }
    },
    "mcpServerDraft": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_-]+$"
        },
        "type": {
          "const": "stdio"
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "args": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["type", "command"]
    }
  }
}
