{
  "name": "code-agent",
  "version": "0.16.80",
  "description": "Local AI cowork workspace with multi-agent orchestration",
  "type": "module",
  "main": "dist/web/webServer.cjs",
  "bin": {
    "code-agent": "./dist/cli/index.cjs"
  },
  "author": "Lin Chen",
  "license": "MIT",
  "scripts": {
    "dev": "npm run dev:cleanup && concurrently -k --kill-others-on-fail \"npm run dev:web:server\" \"npm run dev:renderer\"",
    "dev:cleanup": "lsof -ti:5173 -ti:8180 | xargs kill -9 2>/dev/null || true",
    "dev:renderer": "vite",
    "build": "npm run build:worker && npm run build:web && npm run build:cli && npm run build:renderer",
    "build:renderer": "vite build",
    "lint": "eslint src --ext .ts,.tsx",
    "debt:report": "node scripts/architecture-debt-report.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:swarm:smoke": "vitest run tests/integration/swarm-chain/swarmChain.test.ts tests/renderer/stores/swarmStore.test.ts",
    "test:swarm:e2e": "playwright test --config tests/e2e/playwright.e2e.config.ts tests/e2e/swarm-chain.spec.ts",
    "test:swarm:full": "npm run test:swarm:smoke && npm run test:swarm:e2e",
    "test:e2e:new-session": "playwright test --config tests/e2e/playwright.e2e.config.ts tests/e2e/new-session.e2e.spec.ts",
    "acceptance:browser-computer": "node node_modules/jiti/bin/jiti.js scripts/acceptance/browser-computer-smoke.ts",
    "acceptance:browser-computer-workflow": "node node_modules/jiti/bin/jiti.js scripts/acceptance/browser-computer-workflow-smoke.ts",
    "acceptance:browser-task-benchmark": "node node_modules/jiti/bin/jiti.js scripts/acceptance/browser-task-benchmark.ts",
    "acceptance:browser-computer-system-chrome": "npx tsx scripts/acceptance/browser-computer-system-chrome-smoke.ts",
    "acceptance:browser-computer-background-ax": "npx tsx scripts/acceptance/browser-computer-background-ax-smoke.ts",
    "acceptance:browser-computer-background-cgevent": "npx tsx scripts/acceptance/browser-computer-background-cgevent-smoke.ts",
    "acceptance:browser-computer-ui": "npx tsx scripts/acceptance/browser-computer-ui-smoke.tsx",
    "acceptance:browser-computer-app-host": "npx tsx scripts/acceptance/browser-computer-app-host-smoke.ts",
    "acceptance:agent-runtime-app-host": "npx tsx scripts/acceptance/agent-runtime-app-host-smoke.ts",
    "acceptance:agent-engine-selector": "npx tsx scripts/acceptance/agent-engine-selector-smoke.ts",
    "acceptance:session-persistence": "npm run build:web && npx tsx scripts/acceptance/session-persistence-smoke.ts",
    "acceptance:workbench-menu-panels": "npx tsx scripts/acceptance/workbench-menu-panels-smoke.ts",
    "acceptance:browser-computer-all": "node node_modules/jiti/bin/jiti.js scripts/acceptance/browser-computer-suite.ts",
    "acceptance:native-desktop": "node node_modules/jiti/bin/jiti.js scripts/acceptance/native-desktop-smoke.ts",
    "acceptance:app-host-office": "node node_modules/jiti/bin/jiti.js scripts/acceptance/app-host-office-smoke.ts",
    "acceptance:app-host-office-write": "node node_modules/jiti/bin/jiti.js scripts/acceptance/app-host-office-write.ts",
    "acceptance:mail": "node node_modules/jiti/bin/jiti.js scripts/acceptance/mail-smoke.ts",
    "acceptance:calendar": "node node_modules/jiti/bin/jiti.js scripts/acceptance/calendar-smoke.ts",
    "acceptance:reminders": "node node_modules/jiti/bin/jiti.js scripts/acceptance/reminders-smoke.ts",
    "acceptance:platformer-gameplay-generation": "node node_modules/jiti/bin/jiti.js scripts/acceptance/platformer-gameplay-generation.ts",
    "acceptance:platformer-gameplay-validate": "node node_modules/jiti/bin/jiti.js scripts/acceptance/platformer-gameplay-generation.ts --validate-only --artifact games/generated-platformer-mechanics.html",
    "acceptance:deck": "npx tsx scripts/acceptance/deck-generation.ts",
    "acceptance:deck:record": "npx tsx scripts/acceptance/deck-generation.ts --record",
    "acceptance:deck:rebuild-fixture": "npx tsx scripts/acceptance/fixtures/deck/generate-fixture.ts",
    "acceptance:deck:live": "npx tsx scripts/acceptance/deck-generation.ts --live",
    "acceptance:deck:live:record": "npx tsx scripts/acceptance/deck-generation.ts --live --record",
    "test:generations": "vitest run tests/generations",
    "test:all": "npm run test",
    "build:worker": "mkdir -p dist/main dist/cli && touch dist/main/worker-sandbox.cjs dist/cli/worker-sandbox.cjs",
    "build:node": "npm_config_cache=/tmp/code-agent-npm-cache npx tsx esbuild.config.ts",
    "build:node:dev": "npm_config_cache=/tmp/code-agent-npm-cache npx tsx esbuild.config.ts --dev",
    "build:mcp-server": "npm_config_cache=/tmp/code-agent-npm-cache npx tsx esbuild.config.ts mcp",
    "build:cli": "npm_config_cache=/tmp/code-agent-npm-cache npx tsx esbuild.config.ts cli",
    "smoke:cli": "node scripts/smoke-cli-entry.cjs",
    "build:bridge": "npm_config_cache=/tmp/code-agent-npm-cache npx tsx esbuild.config.ts bridge",
    "dev:cli": "npm_config_cache=/tmp/code-agent-npm-cache npx tsx esbuild.config.ts cli --dev",
    "build:test-runner": "npm_config_cache=/tmp/code-agent-npm-cache npx tsx esbuild.config.ts test-runner",
    "test:research": "bash scripts/test-deep-research.sh",
    "cli": "node dist/cli/index.cjs",
    "mcp-server": "node dist/mcp-server.js",
    "docs": "typedoc",
    "rebuild-native:system": "bash scripts/rebuild-native-system.sh",
    "check:hardcoded": "bash scripts/check-hardcoded-models.sh --all",
    "postinstall": "npm run rebuild-native:system",
    "eval": "npx tsx scripts/eval-ci.ts",
    "regression": "npx tsx scripts/regression-cli.ts",
    "regression:gate": "npx tsx scripts/regression-cli.ts gate",
    "regression:baseline": "npx tsx scripts/regression-cli.ts baseline",
    "proposal": "npx tsx scripts/proposal-cli.ts",
    "attribution": "npx tsx scripts/attribution-cli.ts",
    "proposal:generate": "npx tsx scripts/proposal-generate.ts",
    "eval:smoke": "npx tsx scripts/eval-ci.ts --scope smoke",
    "eval:full": "npx tsx scripts/eval-ci.ts --scope full",
    "eval:baseline": "npx tsx scripts/eval-ci.ts --baseline-info",
    "eval:promote": "npx tsx scripts/eval-ci.ts --promote",
    "eval:trend": "npx tsx scripts/eval-ci.ts --trend",
    "eval:setup-hooks": "bash scripts/setup-eval-hooks.sh",
    "build:web": "npm_config_cache=/tmp/code-agent-npm-cache npx tsx esbuild.config.ts web",
    "dev:web:server": "npm run build:web && node dist/web/webServer.cjs",
    "dev:web": "concurrently -k \"npm run dev:web:server\" \"sleep 2 && npm run dev:renderer\"",
    "tauri:dev": "npm run rebuild-native:system && npm run build:web && cargo tauri dev",
    "tauri:prebuild-cleanup": "bash scripts/tauri-prebuild-cleanup.sh",
    "release:security-scan": "node scripts/release-security-scan.mjs",
    "release:security-scan:bundle": "node scripts/release-security-scan.mjs src-tauri/target/release/bundle/macos",
    "release:resource-inventory": "node scripts/tauri-resource-inventory.mjs",
    "release:runtime-assets": "node scripts/build-runtime-assets.mjs",
    "release:runtime-assets:install": "npx tsx scripts/install-runtime-asset.ts",
    "release:verify-macos": "bash scripts/verify-macos-release.sh",
    "release:notarize-macos": "bash scripts/tauri-notarize.sh",
    "control-plane:release-bundle": "node scripts/control-plane-release-bundle.mjs",
    "control-plane:apply-governance-migration": "node scripts/apply-control-plane-governance-migration.mjs",
    "tauri:package": "npm run rebuild-native:system && npm run build && npm run tauri:prebuild-cleanup && npm run release:security-scan && cargo tauri build",
    "tauri:bundle": "npm run tauri:package && npm run release:verify-macos && bash scripts/tauri-clean-bundle-apps.sh",
    "tauri:build": "npm run tauri:package && npm run release:verify-macos && bash scripts/tauri-install.sh",
    "tauri:release:bundle": "npm run rebuild-native:system && npm run build && npm run tauri:prebuild-cleanup && npm run release:security-scan && bash scripts/tauri-release-bundle.sh && npm run release:notarize-macos && npm run release:verify-macos && bash scripts/tauri-clean-bundle-apps.sh",
    "tauri:update-manifest": "node scripts/tauri-update-manifest.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --fix"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.79",
    "@ai-sdk/deepseek": "^2.0.35",
    "@ai-sdk/openai": "^3.0.65",
    "@ai-sdk/openai-compatible": "^2.0.48",
    "@anthropic-ai/sdk": "^0.97.1",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@larksuiteoapi/node-sdk": "^1.64.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@supabase/supabase-js": "^2.106.1",
    "@tauri-apps/api": "~2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@types/dagre": "^0.7.54",
    "@types/papaparse": "^5.5.2",
    "@ui-tars/sdk": "^1.2.3",
    "@uiw/react-codemirror": "^4.25.9",
    "@xyflow/react": "^12.10.2",
    "ai": "^6.0.191",
    "avr-vad": "^1.0.10",
    "axios": "^1.16.1",
    "better-sqlite3": "^12.10.0",
    "chalk": "^5.6.2",
    "cheerio": "^1.2.0",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "croner": "^10.0.1",
    "dagre": "^0.8.5",
    "diff": "^9.0.0",
    "docx": "^9.6.1",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "glob": "^13.0.6",
    "gpt-tokenizer": "^3.4.0",
    "grammy": "^1.43.0",
    "groq-sdk": "^1.2.0",
    "highlight.js": "^11.11.1",
    "html2canvas": "^1.4.1",
    "https-proxy-agent": "^9.0.0",
    "ink": "^7.0.3",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "js-yaml": "^4.1.1",
    "keytar": "^7.9.0",
    "langfuse": "^3.38.20",
    "mammoth": "^1.12.0",
    "marked": "^18.0.4",
    "mermaid": "^11.15.0",
    "minimatch": "^10.2.5",
    "node-fetch": "^3.3.2",
    "node-pty": "^1.1.0",
    "openai": "^6.38.0",
    "ora": "^9.4.0",
    "papaparse": "^5.5.3",
    "pdfkit": "^0.18.0",
    "picomatch": "^4.0.4",
    "playwright": "^1.60.0",
    "postgres": "^3.4.9",
    "pptxgenjs": "4.0.1",
    "qrcode": "^1.5.4",
    "react-is": "^19.2.6",
    "react-resizable-panels": "^4.11.1",
    "react-virtuoso": "^4.18.7",
    "recharts": "^3.8.1",
    "reflect-metadata": "^0.2.2",
    "remend": "^1.3.0",
    "sharp": "^0.34.5",
    "uuid": "^14.0.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/diff": "^8.0.0",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/minimatch": "^6.0.0",
    "@types/node": "^25.9.1",
    "@types/pdfkit": "^0.17.6",
    "@types/picomatch": "^4.0.3",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.7",
    "autoprefixer": "^10.5.0",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "lucide-react": "^1.16.0",
    "postcss": "^8.5.15",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-katex": "^7.0.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^3.6.0",
