{
  "manifest_version": 3,
  "name": "Agent Neo Browser Relay",
  "version": "0.2.0",
  "description": "Grant Agent Neo time-bound, origin-scoped leases for explicitly approved Chrome tabs.",
  "permissions": ["debugger", "tabs", "activeTab", "storage", "alarms"],
  "host_permissions": ["http://127.0.0.1/*", "http://localhost/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Agent Neo Browser Relay"
  },
  "options_page": "options.html"
}
