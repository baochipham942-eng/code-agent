{
  "manifest_version": 3,
  "name": "Agent Neo Browser Relay",
  "version": "0.1.0",
  "description": "Connect Chrome tabs to Agent Neo through a local, token-protected relay.",
  "permissions": ["debugger", "tabs", "activeTab", "storage", "alarms"],
  "host_permissions": ["<all_urls>", "http://127.0.0.1/*", "http://localhost/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Agent Neo Browser Relay"
  },
  "options_page": "options.html"
}
