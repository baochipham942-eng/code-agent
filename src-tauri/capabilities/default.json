{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for Code Agent",
  "windows": ["main"],
  "remote": {
    "urls": ["http://localhost:8180/*"]
  },
  "permissions": [
    "core:default",
    "updater:default",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister",
    "dialog:allow-open"
  ]
}
