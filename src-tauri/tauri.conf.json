{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agent Neo",
  "version": "0.16.75",
  "identifier": "com.linchen.code-agent",
  "build": {
    "beforeDevCommand": "npm run build:renderer && npm run build:web && (node dist/web/webServer.cjs &) && for i in $(seq 1 60); do curl -sf http://localhost:8180/api/health >/dev/null 2>&1 && break; sleep 0.5; done",
    "devUrl": "http://localhost:8180",
    "frontendDist": "../dist/renderer"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Agent Neo",
        "width": 1200,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "dragDropEnabled": false,
        "visible": false,
        "url": "about:blank"
      }
    ],
    "security": {
      "csp": "default-src 'self' http://localhost:8180 https://localhost:8180 data: blob:; connect-src 'self' http://localhost:8180 ws://localhost:8180 https://localhost:8180 wss://localhost:8180; img-src 'self' data: blob: http://localhost:8180 https://localhost:8180; style-src 'self' 'unsafe-inline' http://localhost:8180 https://localhost:8180; script-src 'self' 'unsafe-inline' 'unsafe-eval' http://localhost:8180 https://localhost:8180; font-src 'self' data: http://localhost:8180 https://localhost:8180; frame-src 'self' http://localhost:* https://localhost:* http://127.0.0.1:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg"
    ],
    "createUpdaterArtifacts": false,
    "category": "Productivity",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "resources": [
      "../dist/web/webServer.cjs",
      "../dist/web/control-plane-public-keys.json",
      "../dist/native/**/*",
      "../dist/renderer/**/*",
      "../resources/browser-relay-extension/**/*",
      "../package.json",
      "../node_modules/better-sqlite3/**/*",
      "../node_modules/keytar/**/*",
      "../node_modules/node-pty/package.json",
      "../node_modules/node-pty/lib/**/*",
      "../node_modules/node-pty/typings/**/*",
      "../node_modules/node-pty/prebuilds/darwin-arm64/**/*",
      "../node_modules/sharp/**/*",
      "../node_modules/@img/colour/**/*",
      "../node_modules/@img/sharp-darwin-arm64/**/*",
      "../node_modules/@img/sharp-libvips-darwin-arm64/**/*",
      "../node_modules/detect-libc/**/*",
      "../node_modules/semver/**/*",
      "../node_modules/playwright/**/*",
      "../node_modules/playwright-core/**/*",
      "../node_modules/onnxruntime-node/package.json",
      "../node_modules/onnxruntime-node/dist/**/*",
      "../node_modules/onnxruntime-node/bin/napi-v6/darwin/arm64/**/*",
      "../node_modules/avr-vad/dist/*.onnx",
      "../scripts/system-audio-capture",
      "../scripts/vision-ocr"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": "Code Agent Dev",
      "entitlements": "Entitlements.plist"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/baochipham942-eng/code-agent/releases/latest/download/latest.json"
      ],
      "pubkey": "DISABLED_LOCAL_BUILD_USE_TAURI_RELEASE_BUNDLE"
    }
  }
}
