{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agent Neo",
  "version": "0.16.86",
  "identifier": "com.linchen.code-agent",
  "build": {
    "beforeDevCommand": "npm run tauri:dev:before",
    "devUrl": "http://localhost:8180",
    "frontendDist": "../dist/renderer"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Agent Neo",
        "width": 1200,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "dragDropEnabled": false,
        "visible": false,
        "url": "about:blank"
      }
    ],
    "security": {
      "csp": "default-src 'self' http://localhost:8180 https://localhost:8180 data: blob:; connect-src 'self' http://localhost:8180 ws://localhost:8180 https://localhost:8180 wss://localhost:8180; img-src 'self' data: blob: http://localhost:8180 https://localhost:8180; style-src 'self' 'unsafe-inline' http://localhost:8180 https://localhost:8180; script-src 'self' 'unsafe-inline' 'unsafe-eval' http://localhost:8180 https://localhost:8180; font-src 'self' data: http://localhost:8180 https://localhost:8180; frame-src 'self' http://localhost:* https://localhost:* http://127.0.0.1:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg"
    ],
    "createUpdaterArtifacts": false,
    "category": "Productivity",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "resources": [
      "../dist/web/webServer.cjs",
      "../dist/web/control-plane-public-keys.json",
      "../dist/native/**/*",
      "../dist/bundled-node/**/*",
      "../dist/renderer/**/*",
      "../resources/browser-relay-extension/**/*",
      "../package.json",
      "../node_modules/better-sqlite3/package.json",
      "../node_modules/better-sqlite3/lib/**/*",
      "../node_modules/better-sqlite3/build/Release/better_sqlite3.node",
      "../node_modules/keytar/**/*",
      "../node_modules/node-pty/package.json",
      "../node_modules/node-pty/lib/conpty_console_list_agent.js",
      "../node_modules/node-pty/lib/eventEmitter2.js",
      "../node_modules/node-pty/lib/index.js",
      "../node_modules/node-pty/lib/interfaces.js",
      "../node_modules/node-pty/lib/shared/conout.js",
      "../node_modules/node-pty/lib/terminal.js",
      "../node_modules/node-pty/lib/types.js",
      "../node_modules/node-pty/lib/unixTerminal.js",
      "../node_modules/node-pty/lib/utils.js",
      "../node_modules/node-pty/lib/windowsConoutConnection.js",
      "../node_modules/node-pty/lib/windowsPtyAgent.js",
      "../node_modules/node-pty/lib/windowsTerminal.js",
      "../node_modules/node-pty/lib/worker/conoutSocketWorker.js",
      "../node_modules/node-pty/prebuilds/darwin-arm64/**/*",
      "../node_modules/sharp/package.json",
      "../node_modules/sharp/lib/*.js",
      "../node_modules/sharp/node_modules/semver/**/*",
      "../node_modules/@img/colour/package.json",
      "../node_modules/@img/colour/*.cjs",
      "../node_modules/@img/sharp-darwin-arm64/package.json",
      "../node_modules/@img/sharp-darwin-arm64/lib/**/*.node",
      "../node_modules/@img/sharp-libvips-darwin-arm64/package.json",
      "../node_modules/@img/sharp-libvips-darwin-arm64/versions.json",
      "../node_modules/@img/sharp-libvips-darwin-arm64/lib/**/*",
      "../node_modules/detect-libc/package.json",
      "../node_modules/detect-libc/lib/**/*",
      "../scripts/system-audio-capture",
      "../scripts/vision-ocr",
      "../scripts/vision-tagger"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": "Code Agent Dev",
      "entitlements": "Entitlements.plist"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/baochipham942-eng/code-agent/releases/latest/download/latest.json"
      ],
      "pubkey": "DISABLED_LOCAL_BUILD_USE_TAURI_RELEASE_BUNDLE"
    }
  }
}
