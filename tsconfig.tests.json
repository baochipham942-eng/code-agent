{
  // tests/ + scripts/ 的类型检查配置——根 tsconfig 的 include 只有 src/**，这两处一直在
  // tsc 门外（2026-07-17 侦察，见 docs/audits/2026-07-17-tsc-gate-blindspot-tests-scripts-debt.md）。
  // 本文件把它们纳入检查，配 scripts/tsc-tests-ratchet.mjs 做只降不升的棘轮清偿。
  "extends": "./tsconfig.json",
  "compilerOptions": {
    // vitest globals（describe/it/expect 等）——vitest.config 里 globals:true，测试文件不 import 也能用。
    "types": ["node", "vitest/globals"],
    // tests/scripts 里大量 import 带显式 .ts 后缀（这些文件由 vitest/tsx 运行，天然支持 .ts import）。
    // noEmit 下开启此项匹配真实运行方式，消掉 82 处 TS5097（非 bug，是检查器配置与运行时不一致）。
    "allowImportingTsExtensions": true
  },
  // src/** 也纳入：不是为了检查 src（根门已管，恒 0），而是让 src 里的 ambient 全局声明
  // （如 window.domainAPI 的 .d.ts 增强）随之加载。否则测试 import 的 src 文件会丢失这些
  // 全局声明，报出一堆纯属配置假象的 src error（实测 designFiles/api 等 ~90 处）。
  "include": ["src/**/*", "tests/**/*", "scripts/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "release",
    // agent-benchmark 的 eval 样例工程（bug-syntax-error/bug-type-error/monorepo-base/express-api…）——
    // 这些是**被测 agent 操作的目标代码库**，不是 code-agent 自己的测试，本就不该进类型门；其中
    // bug-* 系列还是故意写坏的（bug-syntax-error 的 TS1005 会让 tsc 提前中止读数变假）。整目录排除。
    "tests/e2e/claude-e2e/fixtures"
  ]
}
