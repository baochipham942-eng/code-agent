{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": [
    "src/host/index.ts",
    "src/host/agent/agentOrchestrator.ts",
    "src/host/agent/agentLoop.ts",
    "src/host/tools/toolRegistry.ts",
    "src/host/tools/toolExecutor.ts",
    "src/host/services/cloud/cloudConfigService.ts",
    "src/host/services/cloud/featureFlagService.ts",
    "src/host/plugins/pluginRegistry.ts",
    "src/host/planning/planningService.ts",
    "src/host/planning/types.ts",
    "src/host/planning/planManager.ts",
    "src/host/planning/hooksEngine.ts",
    "src/host/planning/errorTracker.ts",
    "src/host/planning/findingsManager.ts",
    "src/shared/types/generation.ts",
    "src/shared/types/skill.ts",
    "src/shared/types/tool.ts",
    "src/shared/types/permission.ts",
    "src/shared/types/model.ts"
  ],
  "out": "docs/api",
  "exclude": [
    "**/node_modules/**",
    "**/*.test.ts",
    "**/*.spec.ts"
  ],
  "excludePrivate": true,
  "excludeProtected": false,
  "excludeInternal": true,
  "name": "Agent Neo API",
  "readme": "none",
  "includeVersion": true,
  "categorizeByGroup": true,
  "sort": ["source-order"],
  "validation": {
    "notExported": false,
    "invalidLink": true,
    "notDocumented": false
  },
  "intentionallyNotExported": [
    "AgentLoopConfig",
    "AgentOrchestratorConfig",
    "ToolExecutorConfig",
    "ExecuteOptions",
    "PluginRegistry",
    "CloudConfigService",
    "FeatureFlagService"
  ]
}
